# Shopify Storefront API — see DEPLOYMENT.md for how to obtain these.

# Your shop's *.myshopify.com domain (not your custom domain).
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token from your Headless / custom app in Shopify admin.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Storefront API version. Check https://shopify.dev/docs/api/usage/versioning
# for the current release and bump this quarterly.
SHOPIFY_STOREFRONT_API_VERSION=2024-10

# Resend (email API) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
